# Database
DATABASE_URL=postgresql://admin:admin123@localhost:5432/finops_db

# Security
SECRET_KEY=your-secret-key-change-in-prod-12345
JWT_SECRET=jwt-secret-key-change-in-prod-12345
ALGORITHM=HS256

# API
DEBUG=True
API_PREFIX=/api/v1
LOG_LEVEL=INFO

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# Features
ENABLE_ANOMALY_DETECTION=True
ENABLE_SCHEDULING=True